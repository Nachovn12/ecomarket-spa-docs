                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status 200 - Inventario consultado correctamente\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Respuesta es un array de registros de inventario\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.be.an('array');",
