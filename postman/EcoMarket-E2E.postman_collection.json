                {
                    "name": "POST ajuste de stock",
                    "description": "Registra un ajuste de stock (entrada o salida) para un producto. El Gerente de Tienda gestiona el inventario según el caso de estudio.",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token_jwt}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"idInventario\": {{idProducto}},\n    \"cantidadAjuste\": 50,\n    \"tipo\": \"ENTRADA\",\n    \"motivo\": \"Ingreso de stock por reabastecimiento desde proveedor\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url_gateway}}/api/inventario/ajustes",
                            "host": ["{{base_url_gateway}}"],
                            "path": ["api", "inventario", "ajustes"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status 201 - Ajuste de stock registrado\", function () { pm.response.to.have.status(201); });",
                                    "pm.test(\"Respuesta contiene tipo de ajuste\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('tipo');",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
