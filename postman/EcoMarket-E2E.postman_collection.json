{
    "info": {
        "name": "EcoMarket SPA - Colección E2E",
        "description": "Colección Postman E2E que cubre los 7 microservicios de EcoMarket SPA para validación durante la defensa técnica EP3. Flujo: login → buscar productos → carrito → pedido → factura → envío → reporte.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "ms-usuarios",
            "description": "Microservicio de Usuarios e Identidad (puerto 8083). Gestiona autenticación, registro y administración de usuarios del sistema.",
            "item": [
                {
                    "name": "POST login",
                    "description": "Autentica al usuario y guarda el JWT en la variable token_jwt para los siguientes requests.",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"correo\": \"admin@ecomarket.cl\",\n    \"password\": \"Password1\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url_gateway}}/api/auth/login",
                            "host": ["{{base_url_gateway}}"],
                            "path": ["api", "auth", "login"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status 200 - Login exitoso\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Respuesta contiene rol del usuario\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('rol');",
                                    "});",
                                    "pm.test(\"Respuesta contiene funcionalidades disponibles\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('funcionalidadesDisponibles');",
                                    "    pm.expect(jsonData.funcionalidadesDisponibles).to.be.an('array').that.is.not.empty;",
                                    "});",
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.token) { pm.collectionVariables.set(\"token_jwt\", jsonData.token); }"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "GET usuarios",
                    "description": "Lista todos los usuarios registrados en el sistema. Solo accesible por ADMINISTRADOR.",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token_jwt}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url_gateway}}/api/usuarios",
                            "host": ["{{base_url_gateway}}"],
                            "path": ["api", "usuarios"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status 200 - Lista de usuarios obtenida\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Respuesta es un array de usuarios\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "ms-catalogo",
            "description": "Microservicio de Catálogo (puerto 8084). Gestiona productos eco-friendly y categorías del marketplace.",
            "item": [
                {
                    "name": "GET productos",
                    "description": "Obtiene el listado completo de productos eco-friendly del catálogo. El cliente puede navegar y buscar productos según el caso de estudio.",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token_jwt}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url_gateway}}/api/productos",
                            "host": ["{{base_url_gateway}}"],
                            "path": ["api", "productos"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status 200 - Catálogo de productos disponible\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Respuesta es un array de productos\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.be.an('array');",
                                    "});",
                                    "pm.test(\"Cada producto tiene SKU y nombre\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    if (jsonData.length > 0) {",
                                    "        pm.expect(jsonData[0]).to.have.property('sku');",
                                    "        pm.expect(jsonData[0]).to.have.property('nombre');",
                                    "        pm.collectionVariables.set(\"idProducto\", jsonData[0].idProducto);",
                                    "    }",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "GET categorias",
                    "description": "Obtiene las categorías de productos disponibles en EcoMarket (ej: Biodegradables, Reutilizables, Orgánicos).",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token_jwt}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url_gateway}}/api/categorias",
                            "host": ["{{base_url_gateway}}"],
                            "path": ["api", "categorias"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status 200 - Categorías del catálogo disponibles\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Respuesta es un array de categorías\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.be.an('array');",
                                    "});",
                                    "pm.test(\"Cada categoría tiene nombre y estado\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    if (jsonData.length > 0) {",
                                    "        pm.expect(jsonData[0]).to.have.property('nombre');",
                                    "        pm.expect(jsonData[0]).to.have.property('estado');",
                                    "    }",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
